APP_ENV=development
APP_DEBUG=false

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_ANSWER=llama-3.3-70b-versatile
GROQ_MODEL_PROMPT_ENHANCER=openai/gpt-oss-20b
GROQ_MODEL_ROUTER=llama-3.1-8b-instant
GROQ_MODEL_SAFETY=openai/gpt-oss-safeguard-20b

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CHROMA_COLLECTION_NAME=medical_chunks
UPLOAD_DIR=uploads
CHROMA_PERSIST_DIRECTORY=vectorstore
DOCUMENTS_REGISTRY_FILE=data/documents.json
MAX_UPLOAD_SIZE_MB=100

RETRIEVAL_DEFAULT_TOP_K=4
RETRIEVAL_STRATEGY=similarity
RETRIEVAL_FETCH_K=20
RETRIEVAL_FINAL_K=4
RETRIEVAL_SCORE_THRESHOLD=1.35
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CONTEXT_MAX_CHARS=12000

RERANKER_ENABLED=false
RERANKER_MODEL_NAME=local_keyword_overlap

ENABLE_LANGGRAPH_RAG=false
ENABLE_OPEN_LITERATURE_ENGINE=true
ENABLE_OPEN_ARTICLE_PIPELINE=true
ENABLE_PROMPT_ENHANCER_V2=true
ENABLE_POST_SAFETY_CHECK=true
ENABLE_GROUNDING_CHECK=true

OPEN_LITERATURE_MAX_CANDIDATES=12
OPEN_LITERATURE_REQUIRE_FULL_TEXT_DEFAULT=false
OPEN_LITERATURE_ALLOWED_SOURCES=
OPEN_LITERATURE_BLOCKED_DOMAINS=localhost,127.0.0.1,::1
OPEN_LITERATURE_ENABLE_GENERIC_HTML=true
OPEN_LITERATURE_ENABLE_CUREUS_EXPERIMENTAL=false

NCBI_EMAIL=
NCBI_TOOL=MARA
NCBI_API_KEY=
